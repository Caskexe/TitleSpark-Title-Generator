<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>TitleSpark Title Generator</title>

	<style>
		* { box-sizing: border-box; }

		body {
			margin: 0;
			background: #0f0f10;
			color: #e6e6e6;
			font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;
		}

		.container {
			max-width: 900px;
			margin: auto;
			padding: 16px;
		}

		h1 {
			font-size: 20px;
			margin-bottom: 10px;
		}
		
		h2 {
			font-size: 14px;
			margin-bottom: 10px;
		}

		.controls {
			position: sticky;
			top: 0;
			background: #0f0f10;
			padding: 10px 0;
			border-bottom: 1px solid #1f1f1f;
			z-index: 10;
		}

		.control-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 10px;
		}

		.full {
			grid-column: 1 / -1;
		}

		label {
			font-size: 12px;
			opacity: 0.7;
			margin-bottom: 4px;
			display: block;
		}

		select, button, input[type="range"] {
			width: 100%;
			padding: 10px;
			border-radius: 8px;
			border: 1px solid #2a2a2a;
			background: #181818;
			color: #fff;
			font-size: 14px;
		}

		button {
			cursor: pointer;
			font-weight: 600;
		}

		#moodLabel {
			font-size: 12px;
			opacity: 0.6;
			margin-top: 4px;
		}

		#results {
			margin-top: 16px;
			display: grid;
			gap: 10px;
		}

		.card {
			padding: 14px;
			border-radius: 12px;
			background: #181818;
			border: 1px solid #262626;
		}

		.title {
			font-size: 15px;
		}

		.copy-hint {
			font-size: 11px;
			opacity: 0.5;
			margin-top: 6px;
		}

		@media (min-width: 600px) {
			#results {
				grid-template-columns: 1fr 1fr;
			}
		}

		@media (min-width: 900px) {
			#results {
				grid-template-columns: 1fr 1fr 1fr;
			}
		}
	</style>
</head>
<body>

<div class="container">

	<h1>TitleSpark Title Generator</h1>
	<h2>Generate fresh song titles, working names, or creative placeholders—slide from dark to bright moods and spark inspiration instantly.</h2>

	<div class="controls">
		<div class="control-grid">

			<div>
				<label>Words</label>
				<select id="wordCount">
					<option value="1">1</option>
					<option value="2">2</option>
					<option value="3" selected>3</option>
					<option value="4">4</option>
					<option value="5">5</option>
					<option value="6">6</option>
					<option value="7">7</option>
				</select>
			</div>

			<div>
				<label>Amount</label>
				<select id="titleCount">
					<option value="1">1</option>
					<option value="5" selected>5</option>
					<option value="10">10</option>
					<option value="15">15</option>
					<option value="20">20</option>
				</select>
			</div>

			<div class="full">
				<label>Mood (Dark → Hopeful)</label>
				<input type="range" id="mood" min="0" max="100" value="50">
				<div id="moodLabel">Neutral</div>
			</div>

			<div class="full">
				<button onclick="generateTitles()">Generate</button>
			</div>

		</div>
	</div>

	<div id="results"></div>

</div>

<script>
	// Dark vs hopeful word banks
	const darkWords = {
		adjectives: ["broken","cold","hollow","fading","lonely","shattered","empty","silent"],
		nouns: ["shadow","night","ghost","silence","distance","storm","ash","void"],
		verbs: ["falling","bleeding","breaking","fading","drifting"],
		connectors: ["without","beneath","inside"]
	};

	const hopefulWords = {
		adjectives: ["golden","bright","open","rising","endless","warm","alive"],
		nouns: ["light","horizon","morning","sky","fire","road","dream"],
		verbs: ["rising","running","calling","shining","holding"],
		connectors: ["into","toward","beyond"]
	};

	const neutralWords = {
		adjectives: ["midnight","distant","wild","quiet","soft"],
		nouns: ["heart","city","echo","rain","time","voice"],
		verbs: ["waiting","turning","moving","searching"],
		connectors: ["in","over","through","of"]
	};

	function pick(arr) {
		return arr[Math.floor(Math.random() * arr.length)];
	}

	function mixPool(dark, neutral, hopeful, mood) {
		// mood 0 = dark, 100 = hopeful
		let pool = [];

		const darkWeight = 100 - mood;
		const hopeWeight = mood;

		for (let i = 0; i < darkWeight / 10; i++) pool.push(...dark);
		for (let i = 0; i < 5; i++) pool.push(...neutral);
		for (let i = 0; i < hopeWeight / 10; i++) pool.push(...hopeful);

		return pool;
	}

	function titleCase(str) {
		return str.replace(/\b\w/g, c => c.toUpperCase());
	}

	function updateMoodLabel(val) {
		const label = document.getElementById("moodLabel");
		if (val < 30) label.textContent = "Dark";
		else if (val < 70) label.textContent = "Balanced";
		else label.textContent = "Hopeful";
	}

	document.getElementById("mood").addEventListener("input", e => {
		updateMoodLabel(e.target.value);
	});

	function generateTitles() {
		const wc = parseInt(document.getElementById("wordCount").value);
		const tc = parseInt(document.getElementById("titleCount").value);
		const mood = parseInt(document.getElementById("mood").value);

		const results = document.getElementById("results");
		results.innerHTML = "";

		const adjPool = mixPool(darkWords.adjectives, neutralWords.adjectives, hopefulWords.adjectives, mood);
		const nounPool = mixPool(darkWords.nouns, neutralWords.nouns, hopefulWords.nouns, mood);
		const verbPool = mixPool(darkWords.verbs, neutralWords.verbs, hopefulWords.verbs, mood);
		const connPool = mixPool(darkWords.connectors, neutralWords.connectors, hopefulWords.connectors, mood);

		for (let i = 0; i < tc; i++) {
			let words = [];

			for (let j = 0; j < wc; j++) {
				const typeRoll = Math.random();

				if (typeRoll < 0.4) words.push(pick(nounPool));
				else if (typeRoll < 0.7) words.push(pick(adjPool));
				else if (typeRoll < 0.9) words.push(pick(verbPool));
				else words.push(pick(connPool));
			}

			const title = titleCase(words.join(" "));

			const card = document.createElement("div");
			card.className = "card";
			card.innerHTML = `
				<div class="title">${title}</div>
				<div class="copy-hint">tap to copy</div>
			`;

			card.onclick = () => {
				navigator.clipboard.writeText(title);
				const hint = card.querySelector(".copy-hint");
				hint.textContent = "copied";
				setTimeout(() => hint.textContent = "tap to copy", 1000);
			};

			results.appendChild(card);
		}
	}

	updateMoodLabel(50);
</script>

</body>
</html>
